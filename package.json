{
    "name": "jty",
    "version": "4.0.0",
    "description": "A minimal type checking library that I need in various projects for safer programming",
    "keywords": [
        "javascript",
        "language",
        "manual type check",
        "type safety",
        "defensive programming",
        "security",
        "verification"
    ],
    "type": "module",
    "exports": {
        "import": "./lib/index.js",
        "types": "./lib/index.d.ts"
    },
    "directories": {
        "lib": "lib",
        "doc": "docs",
        "test": "test"
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "doc": "typedoc src/index.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "fmt": "prettier --write .",
        "test": "npm run typecheck && node --import tsx --test",
        "test:watch": "npm run typecheck && node --import tsx --test --watch",
        "test:coverage": "npm run typecheck && node --import tsx --test --experimental-test-coverage",
        "preversion": "npm t",
        "prepublishOnly": "npm run build",
        "postversion": "git push && git push --tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alexewerlof/jty.git"
    },
    "author": "Alex Ewerlöf",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^24.7.2",
        "prettier": "^3.6.2",
        "tsx": "^4.20.6",
        "typedoc": "^0.28.14",
        "typescript": "^5.9.3"
    }
}
